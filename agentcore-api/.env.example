PORT=5000
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_EXPIRES_IN=15m
AI_CONFIG_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

S3_STORAGE_PROVIDER=s3
S3_REGION=us-east-1
S3_BUCKET=agentcore-knowledge
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
S3_ACCESS_KEY_ID=replace-with-access-key
S3_SECRET_ACCESS_KEY=replace-with-secret-key
S3_UPLOAD_PREFIX=knowledge
MAX_UPLOAD_FILE_SIZE_MB=25

REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=agentcore
KNOWLEDGE_INGESTION_QUEUE_CONCURRENCY=2

DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_EMBEDDING_DIMENSIONS=1536
DEFAULT_CHAT_MODEL=gpt-4.1-mini
