# Core runtime
NODE_ENV=development
PORT=5000
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=agentcore
CORS_ORIGINS=http://localhost:3000

# Secrets (use a secret manager in production)
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
AI_CONFIG_ENCRYPTION_KEY=replace-with-at-least-32-random-characters


# Reverse proxy
TRUST_PROXY_HOPS=0

# Knowledge object storage (required only for knowledge file uploads)
S3_STORAGE_PROVIDER=s3
S3_REGION=us-east-1
S3_BUCKET=agentcore-knowledge
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
# Leave credentials empty when the deployment uses an IAM/workload role.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Workspace-configured AI/OCR providers are stored encrypted in Postgres.
# These values are deployment-wide SSRF/network policy, not provider config.
AI_PROVIDER_ALLOWED_HOSTS=
AI_PROVIDER_ALLOW_PRIVATE_NETWORKS=false
KNOWLEDGE_OCR_ALLOWED_HOSTS=ocr-tesseract:8080
KNOWLEDGE_OCR_ALLOW_PRIVATE_NETWORKS=true

# Malware scanning (optional service; scanning remains fail-closed by default)
CLAMAV_HOST=

# Operations alerts (optional)
KNOWLEDGE_ALERT_WEBHOOK_URL=
APPOINTMENT_OPERATIONS_ALERT_WEBHOOK_URL=
# Lead SLA, retention and durable webhook delivery sweep frequency.
LEAD_OPERATIONS_SWEEP_INTERVAL_MS=30000

# Calendar OAuth (only when calendar sync is enabled)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:5000/api/v1/appointment-booking/calendar/oauth/google/callback
MICROSOFT_CALENDAR_CLIENT_ID=
MICROSOFT_CALENDAR_CLIENT_SECRET=
MICROSOFT_CALENDAR_REDIRECT_URI=http://localhost:5000/api/v1/appointment-booking/calendar/oauth/microsoft/callback
APPOINTMENT_CALENDAR_OAUTH_SUCCESS_URL=http://localhost:3000/?tab=appointments&calendar=connected

# Appointment email/SMS delivery (only for enabled channels)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
APPOINTMENT_EMAIL_FROM="Appointments <appointments@example.com>"
APPOINTMENT_PUBLIC_URL=http://localhost:3000
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=

# Twilio browser softphone (optional)
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=

# Voice/WhatsApp public callback origins and deployment kill switches
VOICE_WEBHOOK_PUBLIC_BASE_URL=
VOICE_CONVERSATION_RELAY_PUBLIC_BASE_URL=
WHATSAPP_WEBHOOK_PUBLIC_BASE_URL=
VOICE_RELAY_SIGNING_SECRET=
WHATSAPP_OUTBOUND_MODE=mock
VOICE_OUTBOUND_MODE=mock
