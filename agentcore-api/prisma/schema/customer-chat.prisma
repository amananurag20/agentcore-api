model CustomerChatConversation {
  id                    String                         @id @default(uuid())
  organizationId        String                         @map("organization_id")
  organization          Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status                CustomerChatConversationStatus @default(open)
  visitorId             String?                        @map("visitor_id")
  visitorName           String?                        @map("visitor_name")
  visitorEmail          String?                        @map("visitor_email")
  visitorTokenHash      String?                        @map("visitor_token_hash")
  visitorTokenExpiresAt DateTime?                      @map("visitor_token_expires_at")
  widgetConfigId        String?                        @map("widget_config_id")
  widgetConfig          CustomerChatWidgetConfig?      @relation(fields: [widgetConfigId], references: [id], onDelete: SetNull)
  assignedAgentId       String?                        @map("assigned_agent_id")
  assignedAgent         User?                          @relation(fields: [assignedAgentId], references: [id], onDelete: SetNull)
  handoffRequestedAt    DateTime?                      @map("handoff_requested_at")
  lastMessageAt         DateTime                       @default(now()) @map("last_message_at")
  expiresAt             DateTime?                      @map("expires_at")
  version               Int                            @default(0)
  metadata              Json                           @default("{}")
  messages              CustomerChatMessage[]
  createdAt             DateTime                       @default(now()) @map("created_at")
  updatedAt             DateTime                       @updatedAt @map("updated_at")

  @@index([organizationId, status])
  @@index([assignedAgentId])
  @@index([visitorId])
  @@index([visitorTokenHash])
  @@index([widgetConfigId])
  @@index([organizationId, lastMessageAt])
  @@index([expiresAt])
  @@map("customer_chat_conversations")
}

model CustomerChatWidgetConfig {
  id             String                              @id @default(uuid())
  organizationId String                              @map("organization_id")
  organization   Organization                        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String                              @default("Website Assistant")
  widgetKey      String                              @unique @default(uuid()) @map("widget_key")
  enabled        Boolean                             @default(true)
  knowledgeScope String                              @default("all") @map("knowledge_scope")
  greetingText   String                              @default("Hi! How can I help you today?") @map("greeting_text")
  allowedDomains String[]                            @default([]) @map("allowed_domains")
  settings       Json                                @default("{}")
  folderScopes   CustomerChatWidgetKnowledgeFolder[]
  conversations  CustomerChatConversation[]
  createdAt      DateTime                            @default(now()) @map("created_at")
  updatedAt      DateTime                            @updatedAt @map("updated_at")

  @@index([organizationId, enabled])
  @@index([enabled])
  @@map("customer_chat_widget_configs")
}

model CustomerChatWidgetKnowledgeFolder {
  widgetConfigId String                   @map("widget_config_id")
  widgetConfig   CustomerChatWidgetConfig @relation(fields: [widgetConfigId], references: [id], onDelete: Cascade)
  folderId       String                   @map("folder_id")
  folder         KnowledgeFolder          @relation(fields: [folderId], references: [id], onDelete: Cascade)
  createdAt      DateTime                 @default(now()) @map("created_at")

  @@id([widgetConfigId, folderId])
  @@index([folderId])
  @@map("customer_chat_widget_knowledge_folders")
}

model CustomerChatMessage {
  id              String                   @id @default(uuid())
  organizationId  String                   @map("organization_id")
  organization    Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversationId  String                   @map("conversation_id")
  conversation    CustomerChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  clientMessageId String?                  @map("client_message_id")
  role            CustomerChatMessageRole
  content         String
  metadata        Json                     @default("{}")
  citations       CustomerChatCitation[]
  createdAt       DateTime                 @default(now()) @map("created_at")

  @@unique([conversationId, clientMessageId])
  @@index([organizationId])
  @@index([conversationId, createdAt])
  @@map("customer_chat_messages")
}

model CustomerChatCitation {
  id        String              @id @default(uuid())
  messageId String              @map("message_id")
  message   CustomerChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  chunkId   String              @map("chunk_id")
  chunk     KnowledgeChunk      @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  score     Float
  createdAt DateTime            @default(now()) @map("created_at")

  @@index([messageId])
  @@index([chunkId])
  @@map("customer_chat_citations")
}
