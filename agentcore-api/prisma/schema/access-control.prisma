model CustomRole {
  id             String                    @id @default(uuid())
  organizationId String                    @map("organization_id")
  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  clearanceLevel Int                       @default(0) @map("clearance_level")
  isTemplate     Boolean                   @default(false) @map("is_template")
  isActive       Boolean                   @default(true) @map("is_active")
  createdById    String?                   @map("created_by_id")
  productAccess  CustomRoleProductAccess[]
  assignments    UserCustomRole[]
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")

  @@unique([organizationId, name])
  @@index([organizationId, isActive])
  @@map("custom_roles")
}

model CustomRoleProductAccess {
  id                 String     @id @default(uuid())
  customRoleId       String     @map("custom_role_id")
  productKey         ProductKey @map("product_key")
  canUse             Boolean    @default(true) @map("can_use")
  canConfigure       Boolean    @default(false) @map("can_configure")
  canManageAgents    Boolean    @default(false) @map("can_manage_agents")
  canManageKnowledge Boolean    @default(false) @map("can_manage_knowledge")
  customRole         CustomRole @relation(fields: [customRoleId], references: [id], onDelete: Cascade)
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  @@unique([customRoleId, productKey])
  @@index([productKey])
  @@map("custom_role_product_access")
}

model UserCustomRole {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  customRoleId   String       @map("custom_role_id")
  organizationId String       @map("organization_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  customRole     CustomRole   @relation(fields: [customRoleId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedById   String?      @map("assigned_by_id")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([userId, customRoleId])
  @@index([organizationId, customRoleId])
  @@map("user_custom_roles")
}
