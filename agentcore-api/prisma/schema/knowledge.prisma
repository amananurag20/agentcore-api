model KnowledgeSource {
  id             String                @id @default(uuid())
  organizationId String                @map("organization_id")
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           KnowledgeSourceType
  status         KnowledgeSourceStatus @default(pending)
  name           String
  url            String?
  fileName       String?               @map("file_name")
  mimeType       String?               @map("mime_type")
  storageProvider StorageProvider?     @map("storage_provider")
  storageBucket  String?               @map("storage_bucket")
  storageKey     String?               @map("storage_key")
  fileSizeBytes  BigInt?               @map("file_size_bytes")
  checksumSha256 String?               @map("checksum_sha256")
  rawText        String?               @map("raw_text")
  metadata       Json                  @default("{}")
  errorMessage   String?               @map("error_message")
  lastIngestedAt DateTime?             @map("last_ingested_at")
  documents      KnowledgeDocument[]
  chunks         KnowledgeChunk[]
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  @@index([organizationId, status])
  @@index([type])
  @@map("knowledge_sources")
}

model KnowledgeDocument {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceId       String?          @map("source_id")
  source         KnowledgeSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  title          String
  uri            String?
  contentText    String?          @map("content_text")
  metadata       Json             @default("{}")
  chunks         KnowledgeChunk[]
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([sourceId])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id             String             @id @default(uuid())
  organizationId String             @map("organization_id")
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceId       String?            @map("source_id")
  source         KnowledgeSource?   @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  documentId     String             @map("document_id")
  document       KnowledgeDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex     Int                @map("chunk_index")
  content        String
  charCount      Int                @map("char_count")
  tokenEstimate  Int                @map("token_estimate")
  embedding      Unsupported("vector")?
  embeddingModel String?            @map("embedding_model")
  embeddingProvider AIProviderType? @map("embedding_provider")
  embeddedAt     DateTime?          @map("embedded_at")
  metadata       Json               @default("{}")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  @@unique([documentId, chunkIndex])
  @@index([organizationId])
  @@index([sourceId])
  @@index([documentId])
  @@index([embeddingProvider])
  @@map("knowledge_chunks")
}
