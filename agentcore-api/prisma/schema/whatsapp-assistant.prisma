model WhatsAppAssistantConfig {
  id                          String                 @id @default(uuid())
  organizationId              String                 @map("organization_id")
  organization                Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider                    WhatsAppProviderType   @default(meta)
  status                      WhatsAppConfigStatus   @default(active)
  name                        String
  phoneNumberId               String?                @map("phone_number_id")
  businessAccountId           String?                @map("business_account_id")
  accessTokenEncrypted        String?                @map("access_token_encrypted")
  webhookVerifyTokenEncrypted String?                @map("webhook_verify_token_encrypted")
  appSecretEncrypted          String?                @map("app_secret_encrypted")
  defaultLocale               String                 @default("en") @map("default_locale")
  settings                    Json                   @default("{}")
  conversations               WhatsAppConversation[]
  templates                   WhatsAppTemplate[]
  createdAt                   DateTime               @default(now()) @map("created_at")
  updatedAt                   DateTime               @updatedAt @map("updated_at")

  @@index([organizationId, status])
  @@index([phoneNumberId])
  @@map("whatsapp_assistant_configs")
}

model WhatsAppTemplate {
  id                 String                  @id @default(uuid())
  organizationId     String                  @map("organization_id")
  organization       Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  configId           String                  @map("config_id")
  config             WhatsAppAssistantConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  providerTemplateId String?                 @map("provider_template_id")
  name               String
  language           String
  status             String
  category           String?
  components         Json                    @default("[]")
  source             String                  @default("meta")
  rejectionReason    String?                 @map("rejection_reason")
  submittedAt        DateTime?               @map("submitted_at")
  syncedAt           DateTime                @default(now()) @map("synced_at")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @updatedAt @map("updated_at")

  @@unique([configId, name, language])
  @@index([organizationId, status])
  @@index([configId, language, status])
  @@map("whatsapp_templates")
}

model WhatsAppConversation {
  id                       String                     @id @default(uuid())
  organizationId           String                     @map("organization_id")
  organization             Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  configId                 String                     @map("config_id")
  config                   WhatsAppAssistantConfig    @relation(fields: [configId], references: [id], onDelete: Cascade)
  status                   WhatsAppConversationStatus @default(open)
  contactWaId              String                     @map("contact_wa_id")
  contactName              String?                    @map("contact_name")
  contactPhone             String?                    @map("contact_phone")
  locale                   String                     @default("en")
  assignedAgentId          String?                    @map("assigned_agent_id")
  assignedAgent            User?                      @relation(fields: [assignedAgentId], references: [id], onDelete: SetNull)
  consentStatus            WhatsAppConsentStatus      @default(unknown) @map("consent_status")
  consentSource            String?                    @map("consent_source")
  consentedAt              DateTime?                  @map("consented_at")
  optedOutAt               DateTime?                  @map("opted_out_at")
  sessionExpiresAt         DateTime?                  @map("session_expires_at")
  processingLeaseMessageId String?                    @map("processing_lease_message_id")
  processingLeaseExpiresAt DateTime?                  @map("processing_lease_expires_at")
  lastMessageAt            DateTime                   @default(now()) @map("last_message_at")
  metadata                 Json                       @default("{}")
  messages                 WhatsAppMessage[]
  createdAt                DateTime                   @default(now()) @map("created_at")
  updatedAt                DateTime                   @updatedAt @map("updated_at")

  @@unique([configId, contactWaId])
  @@index([organizationId, status])
  @@index([assignedAgentId])
  @@index([contactWaId])
  @@index([lastMessageAt])
  @@map("whatsapp_conversations")
}

model WhatsAppMessage {
  id                 String                   @id @default(uuid())
  organizationId     String                   @map("organization_id")
  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversationId     String                   @map("conversation_id")
  conversation       WhatsAppConversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction          WhatsAppMessageDirection
  role               WhatsAppMessageRole
  type               WhatsAppMessageType      @default(text)
  providerMessageId  String?                  @map("provider_message_id")
  automationKey      String?                  @unique @map("automation_key")
  content            String?
  mediaUrl           String?                  @map("media_url")
  mediaMimeType      String?                  @map("media_mime_type")
  mediaSha256        String?                  @map("media_sha256")
  mediaStorageBucket String?                  @map("media_storage_bucket")
  mediaStorageKey    String?                  @map("media_storage_key")
  mediaSizeBytes     Int?                     @map("media_size_bytes")
  processedAt        DateTime?                @map("processed_at")
  processingError    String?                  @map("processing_error")
  processingAttempts Int                      @default(0) @map("processing_attempts")
  deliveryStatus     String?                  @map("delivery_status")
  deliveryError      String?                  @map("delivery_error")
  deliveryAttempts   Int                      @default(0) @map("delivery_attempts")
  deliveredAt        DateTime?                @map("delivered_at")
  metadata           Json                     @default("{}")
  createdAt          DateTime                 @default(now()) @map("created_at")

  @@unique([organizationId, direction, providerMessageId])
  @@index([organizationId])
  @@index([conversationId, createdAt])
  @@index([processedAt])
  @@index([organizationId, deliveryStatus])
  @@map("whatsapp_messages")
}

model WhatsAppPendingDeliveryStatus {
  id                String       @id @default(uuid())
  organizationId    String       @map("organization_id")
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  providerMessageId String       @map("provider_message_id")
  status            String
  callbackAt        DateTime     @map("callback_at")
  recipientWaId     String?      @map("recipient_wa_id")
  errors            Json         @default("[]")
  metadata          Json         @default("{}")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  @@unique([organizationId, providerMessageId])
  @@index([createdAt])
  @@map("whatsapp_pending_delivery_statuses")
}
